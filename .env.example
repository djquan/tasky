# Y-Sweet Configuration
# Generate a secure key with: openssl rand -base64 32
SESSION_BACKEND_KEY=your-secure-key-here-generate-with-openssl-rand-base64-32

# Y-Sweet Client URL
# This is the WebSocket URL that clients will use to connect
# For Tailscale: ws://your-tailscale-ip:8080
# For production domain: wss://your-domain.com:8080
YSWEET_CLIENT_URL=ws://localhost:8080

# Document ID (optional, defaults to tasky-main)
DOCUMENT_ID=tasky-main
