# Tasky Backend Configuration
# Copy this file to .env and update with your values

# Backend listening port (nginx entry point)
BACKEND_PORT=8080

# Y-Sweet session encryption key
# IMPORTANT: Generate a secure key for production using:
#   openssl rand -base64 32
SESSION_BACKEND_KEY=dev-key-change-in-production-use-openssl-rand-base64-32

# Document identifier (all clients sync to this document)
DOCUMENT_ID=tasky-main

# Note: No URL configuration needed on the backend!
# The web app only needs to know the backend base URL (e.g., http://localhost:8080)
# The client automatically:
# - Appends /token to fetch connection details
# - Constructs WebSocket URL from the same base
#
# Example: Backend URL http://localhost:8080 becomes:
#   - Token endpoint: http://localhost:8080/token
#   - WebSocket: ws://localhost:8080/d/tasky-main/ws
